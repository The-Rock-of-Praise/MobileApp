default_platform(:ios)

platform :ios do
  desc "Push a new release build to the App Store"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],
      is_key_content_base64: false
    )

    # Automatically fetch/create distribution certificates and provisioning profiles
    get_certificates(api_key: api_key)
    get_provisioning_profile(api_key: api_key, type: "app-store")

    # Build the IPA
    # Note: Fastlane gym will handle the build and signing
    build_app(
      scheme: "Runner",
      workspace: "Runner.xcworkspace",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "TheRockOfPraise.ipa",
      clean: true,
      api_key: api_key
    )
  end
end
